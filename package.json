{
  "name": "shadow-trader",
  "version": "1.0.0",
  "description": "AI trading agent with privacy - trades without exposing wallet history",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "node --watch server/index.js",
    "dev:client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "start": "node server/index.js"
  },
  "dependencies": {
    "@solana/web3.js": "^1.95.0",
    "tweetnacl": "^1.0.3",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "openai": "^4.28.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
