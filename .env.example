# Backend Environment Variables (for Railway)

# Required for AI commands
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Required for live trading (get from https://discord.gg/vanishtrade)
VANISH_API_KEY=

# Optional - for encrypted strategy storage
ARCIUM_API_KEY=
ARCIUM_ENCRYPTION_KEY=

# Optional - defaults to public RPC
SOLANA_RPC_URL=

# Server port (Railway sets this automatically)
PORT=3001
